#ifndef WIFI_CONFIG_H
#define WIFI_CONFIG_H

// Copy this file to wifi_config.h and fill in your 2.4 GHz WiFi credentials.
// The ESP32 on the Waveshare board only supports 2.4 GHz WiFi (not 5 GHz).

#define WIFI_SSID "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// Password for ArduinoOTA (over-the-air upload). Must match PlatformIO upload_flags --auth=...
#define OTA_PASSWORD "your-ota-password"

#endif
